# Google service-account credentials for the Sheets (team, research) and
# Calendar (events) integrations. Copy to .env.local for development and set
# the same variables in Netlify (Site settings → Environment variables) for
# production.
#
# Get these from a service-account key in the "waisi-org" Google Cloud project:
#   IAM & Admin → Service Accounts → Keys → Add key (JSON), then copy the
#   "client_email" and "private_key" fields.
GOOGLE_CLIENT_EMAIL=your-service-account@waisi-org.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
